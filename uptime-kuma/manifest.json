{
    "name": "Uptime Kuma",
    "code": "uptime-kuma",
    "type": "application",
    "version": "2",
    "description": "Monitor your websites and services with instant alerts when something goes down.",
    "url": "https://uptime.kuma.pet",
    "documentation": "https://github.com/louislam/uptime-kuma/wiki",
    "category": "monitoring",
    "tenancy": [
        "multi-tenant"
    ],
    "components": [
        {
            "name": "uptime-kuma",
            "type": "deployment",
            "image": "louislam/uptime-kuma:2",
            "ports": [
                {
                    "port": 3001,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and status page"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "name": "uptime-kuma-data",
            "mount_path": "/app/data",
            "default_size": "1Gi",
            "description": "Uptime Kuma data and SQLite database"
        }
    ],
    "resources": {
        "default": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "1Gi"
        },
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi",
            "storage": "1Gi"
        }
    },
    "health_check": {
        "path": "/api/health",
        "port": 3001,
        "initial_delay_seconds": 15,
        "period_seconds": 10
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "kumaData.storageSize",
            "label": "Data Storage Size",
            "type": "string",
            "default": "1Gi"
        }
    ],
    "tags": [
        "monitoring",
        "uptime",
        "status-page"
    ],
    "supportedVersions": [
        {
            "version": "1",
            "components": [
                {
                    "name": "uptime-kuma",
                    "image": "louislam/uptime-kuma:1"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Uptime Kuma 1.x reaches end-of-life September 2026. Upgrade to 2.x.",
            "isDefault": false
        },
        {
            "version": "2",
            "components": [
                {
                    "name": "uptime-kuma",
                    "image": "louislam/uptime-kuma:2"
                }
            ],
            "upgradeFrom": [
                "1"
            ],
            "breakingChanges": "Major version upgrade. Node.js runtime updated.",
            "isDefault": true
        }
    ]
}
