{
    "name": "Rocket.Chat",
    "code": "rocketchat",
    "type": "application",
    "version": "8",
    "description": "Team messaging and collaboration with channels, direct messages, video calls, and file sharing.",
    "url": "https://www.rocket.chat",
    "documentation": "https://docs.rocket.chat",
    "category": "communication",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "rocketchat",
            "type": "deployment",
            "image": "rocket.chat:8",
            "ports": [
                {
                    "port": 3000,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "uploads"
            ]
        },
        {
            "name": "mongodb",
            "type": "deployment",
            "image": "mongo:8",
            "command": [
                "bash",
                "-c",
                "set -e\nmongod --replSet rs0 --bind_ip_all &\nMONGOD_PID=$!\nuntil mongosh --quiet --eval 'db.adminCommand({ping:1})' >/dev/null 2>&1; do sleep 1; done\nif ! mongosh --quiet --eval 'rs.status().ok' 2>/dev/null | grep -q '^1'; then\n  mongosh --quiet --eval 'rs.initiate({_id:\"rs0\",members:[{_id:0,host:\"localhost:27017\"}]})'\nfi\nwait $MONGOD_PID\n"
            ],
            "ports": [
                {
                    "port": 27017,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI"
            }
        ],
        "host_ports": [],
        "websocket": true
    },
    "volumes": [
        {
            "local_path": "uploads",
            "container_path": "/app/uploads",
            "description": "Rocket.Chat file uploads"
        },
        {
            "local_path": "database",
            "container_path": "/data/db",
            "description": "MongoDB data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "1.00",
            "memory": "1Gi",
            "storage": "10Gi"
        },
        "recommended": {
            "cpu": "2.00",
            "memory": "2Gi",
            "storage": "20Gi"
        }
    },
    "health_check": {
        "path": "/api/info",
        "port": 3000,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "rocketchat.adminUser",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "rocketchat.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "rocketchat.adminEmail",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "mongodb.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "10Gi"
        },
        {
            "key": "rcUploads.storageSize",
            "label": "Uploads Storage Size",
            "type": "string",
            "default": "10Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "chat",
        "messaging",
        "rocketchat",
        "communication"
    ],
    "supportedVersions": [
        {
            "version": "7",
            "components": [
                {
                    "name": "rocketchat",
                    "image": "rocket.chat:7"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Rocket.Chat 7.x reaches end-of-life September 2026. Upgrade to 8.x.",
            "isDefault": false
        },
        {
            "version": "8",
            "components": [
                {
                    "name": "rocketchat",
                    "image": "rocket.chat:8"
                }
            ],
            "upgradeFrom": [
                "7"
            ],
            "breakingChanges": "Major version upgrade. Apps marketplace changes.",
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [],
        "fixed": {
            "MONGO_URL": "mongodb://{{SERVICE:mongodb}}:27017/rocketchat?replicaSet=rs0",
            "MONGO_OPLOG_URL": "mongodb://{{SERVICE:mongodb}}:27017/local?replicaSet=rs0",
            "NODE_OPTIONS": "--max-old-space-size=768",
            "DEPLOY_METHOD": "docker",
            "OVERWRITE_SETTING_Show_Setup_Wizard": "pending"
        },
        "configurable": [
            "ROOT_URL"
        ]
    }
}
