{
    "name": "Apache + PHP 8.3",
    "code": "apache-php83",
    "type": "runtime",
    "version": "8.3",
    "description": "Apache HTTP Server with mod_php 8.3 for traditional PHP hosting with .htaccess support",
    "category": "runtime",
    "min_plan": "starter",
    "runtime": "php",
    "web_server": "apache",
    "image": null,
    "has_dockerfile": true,
    "deployment_strategy": "deployment",
    "components": [
        {
            "name": "apache-php83",
            "type": "deployment",
            "image": "ghcr.io/phoenixtechnam/k8s-application-catalog/apache-php83:8.3",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web traffic"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "website_files",
            "container_path": "/var/www/html",
            "size_megabytes": 5120,
            "description": "Document root"
        }
    ],
    "resources": {
        "default": {
            "cpu": "0.25",
            "memory": "256Mi"
        },
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi"
        }
    },
    "health_check": {
        "path": "/",
        "command": null,
        "port": 80,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "env.PHP_MEMORY_LIMIT",
            "label": "Php Memory Limit",
            "type": "string"
        },
        {
            "key": "env.PHP_UPLOAD_MAX_FILESIZE",
            "label": "Php Upload Max Filesize",
            "type": "string"
        }
    ],
    "tags": [
        "php",
        "apache",
        "web",
        "htaccess"
    ],
    "services": {
        "database": {
            "required": false,
            "engines": [
                {
                    "type": "mariadb",
                    "min_version": "10.4"
                },
                {
                    "type": "mysql",
                    "min_version": "5.7"
                }
            ],
            "env_mapping": {
                "host": "DB_HOST",
                "port": "DB_PORT",
                "name": "DB_NAME",
                "user": "DB_USER",
                "password": "DB_PASSWORD"
            }
        }
    },
    "env_vars": {
        "configurable": [
            "PHP_MEMORY_LIMIT",
            "PHP_UPLOAD_MAX_FILESIZE"
        ],
        "fixed": {}
    }
}
