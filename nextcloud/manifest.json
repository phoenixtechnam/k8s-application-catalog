{
    "name": "Nextcloud",
    "code": "nextcloud",
    "type": "application",
    "version": "33",
    "description": "Your own private cloud for files, calendars, contacts, and real-time document collaboration.",
    "url": "https://nextcloud.com",
    "documentation": "https://docs.nextcloud.com",
    "category": "productivity",
    "tenancy": [
        "single-tenant",
        "multi-tenant"
    ],
    "components": [
        {
            "name": "nextcloud",
            "type": "deployment",
            "image": "nextcloud:33-apache",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        },
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11.8",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        },
        {
            "name": "redis",
            "type": "deployment",
            "image": "redis:8-alpine",
            "ports": [
                {
                    "port": 6379,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "optional": true
        },
        {
            "name": "collabora",
            "type": "deployment",
            "image": "collabora/code:25.04",
            "ports": [
                {
                    "port": 9980,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "optional": true
        },
        {
            "name": "cron",
            "type": "cronjob",
            "image": "nextcloud:33-apache",
            "schedule": "*/5 * * * *"
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI, WebDAV, CalDAV, CardDAV"
            }
        ],
        "host_ports": [],
        "websocket": true,
        "notes": "WebDAV/CalDAV/CardDAV all work over standard HTTPS port. Collabora (if enabled) is accessed via the same ingress with a /cool/ path prefix."
    },
    "volumes": [
        {
            "local_path": "applications/nextcloud/data",
            "container_path": "/var/www/html/data",
            "description": "User files, uploads, and shared data"
        },
        {
            "local_path": "applications/nextcloud/config",
            "container_path": "/var/www/html/config",
            "description": "Nextcloud configuration files"
        },
        {
            "local_path": "applications/nextcloud/apps",
            "container_path": "/var/www/html/custom_apps",
            "description": "Installed Nextcloud apps"
        },
        {
            "local_path": "applications/nextcloud/database",
            "container_path": "/var/lib/mysql",
            "description": "MariaDB data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "10Gi"
        },
        "recommended": {
            "cpu": "1.00",
            "memory": "1Gi",
            "storage": "56Gi"
        }
    },
    "health_check": {
        "path": "/status.php",
        "port": 80,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "nextcloud.adminUser",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "nextcloud.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "nextcloud.trustedDomains",
            "label": "Trusted Domains",
            "type": "string",
            "required": true,
            "description": "Space-separated list of trusted domains"
        },
        {
            "key": "nextcloud.defaultPhoneRegion",
            "label": "Default Phone Region",
            "type": "string",
            "default": "US"
        },
        {
            "key": "nextcloud.smtpHost",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "nextcloud.smtpPort",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "nextcloud.smtpUser",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "nextcloud.smtpPassword",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        },
        {
            "key": "nextcloud.smtpFromAddress",
            "label": "SMTP From Address",
            "type": "string",
            "required": false
        },
        {
            "key": "redis.enabled",
            "label": "Enable Redis Cache",
            "type": "boolean",
            "default": true
        },
        {
            "key": "collabora.enabled",
            "label": "Enable Collabora Online (document editing)",
            "type": "boolean",
            "default": false
        },
        {
            "key": "collabora.domain",
            "label": "Collabora Domain",
            "type": "string",
            "required": false,
            "description": "Separate domain for Collabora (e.g., office.example.com)"
        },
        {
            "key": "nextcloud.dataStorageSize",
            "label": "Data Storage Size",
            "type": "string",
            "default": "50Gi"
        },
        {
            "key": "mariadb.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        }
    ],
    "tags": [
        "productivity",
        "file-sharing",
        "collaboration",
        "webdav",
        "caldav",
        "carddav",
        "office"
    ],
    "supportedVersions": [
        {
            "version": "32",
            "components": [
                {
                    "name": "nextcloud",
                    "image": "nextcloud:32-apache"
                },
                {
                    "name": "cron",
                    "image": "nextcloud:32-apache"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Nextcloud upgrades must be sequential. Upgrade to 33 before any future version.",
            "isDefault": false
        },
        {
            "version": "33",
            "components": [
                {
                    "name": "nextcloud",
                    "image": "nextcloud:33-apache"
                },
                {
                    "name": "cron",
                    "image": "nextcloud:33-apache"
                }
            ],
            "upgradeFrom": [
                "32"
            ],
            "isDefault": true
        }
    ]
}
