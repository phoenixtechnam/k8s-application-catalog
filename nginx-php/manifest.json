{
    "name": "NGINX + PHP",
    "code": "nginx-php",
    "type": "runtime",
    "version": "8.4",
    "description": "NGINX web server with PHP-FPM for modern PHP applications (serversideup/php)",
    "category": "runtime",
    "min_plan": "starter",
    "runtime": "php",
    "web_server": "nginx",
    "image": "serversideup/php:8.4-fpm-nginx-alpine",
    "has_dockerfile": false,
    "deployment_strategy": "deployment",
    "components": [
        {
            "name": "nginx-php",
            "type": "deployment",
            "image": "serversideup/php:8.4-fpm-nginx-alpine",
            "ports": [
                {
                    "port": 8080,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web traffic"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "website_files",
            "container_path": "/var/www/html",
            "description": "Document root"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi"
        },
        "recommended": {
            "cpu": "0.25",
            "memory": "256Mi"
        }
    },
    "health_check": {
        "path": "/healthcheck",
        "command": null,
        "port": 8080,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "env.PHP_MEMORY_LIMIT",
            "label": "PHP Memory Limit",
            "type": "string"
        },
        {
            "key": "env.PHP_UPLOAD_MAX_FILE_SIZE",
            "label": "PHP Upload Max File Size",
            "type": "string"
        },
        {
            "key": "env.PHP_POST_MAX_SIZE",
            "label": "PHP Post Max Size",
            "type": "string"
        },
        {
            "key": "env.PHP_MAX_EXECUTION_TIME",
            "label": "PHP Max Execution Time",
            "type": "string"
        },
        {
            "key": "env.PHP_OPCACHE_ENABLE",
            "label": "Enable OPcache",
            "type": "string"
        }
    ],
    "tags": [
        "php",
        "nginx",
        "web"
    ],
    "services": {
        "database": {
            "required": false,
            "engines": [
                {
                    "type": "mariadb",
                    "min_version": "10.4"
                },
                {
                    "type": "mysql",
                    "min_version": "5.7"
                }
            ],
            "env_mapping": {
                "host": "DB_HOST",
                "port": "DB_PORT",
                "name": "DB_NAME",
                "user": "DB_USER",
                "password": "DB_PASSWORD"
            }
        }
    },
    "env_vars": {
        "configurable": [
            "PHP_MEMORY_LIMIT",
            "PHP_UPLOAD_MAX_FILE_SIZE",
            "PHP_POST_MAX_SIZE",
            "PHP_MAX_EXECUTION_TIME",
            "PHP_OPCACHE_ENABLE"
        ],
        "fixed": {}
    },
    "supportedVersions": [
        {
            "version": "8.3",
            "isDefault": false,
            "upgradeFrom": [],
            "components": [
                {
                    "name": "nginx-php",
                    "image": "serversideup/php:8.3-fpm-nginx-alpine"
                }
            ]
        },
        {
            "version": "8.4",
            "isDefault": true,
            "upgradeFrom": [
                "8.3"
            ],
            "components": [
                {
                    "name": "nginx-php",
                    "image": "serversideup/php:8.4-fpm-nginx-alpine"
                }
            ]
        },
        {
            "version": "8.5",
            "isDefault": false,
            "upgradeFrom": [
                "8.4"
            ],
            "components": [
                {
                    "name": "nginx-php",
                    "image": "serversideup/php:8.5-fpm-nginx-alpine"
                }
            ]
        }
    ]
}
