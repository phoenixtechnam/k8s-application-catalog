{
    "name": "Jitsi Meet",
    "code": "jitsi",
    "type": "application",
    "version": "stable-10741",
    "description": "Host secure video meetings and conferences on your own server — no account required for participants.",
    "url": "https://jitsi.org",
    "documentation": "https://jitsi.github.io/handbook/",
    "category": "communication",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "web",
            "type": "deployment",
            "image": "jitsi/web:stable-10741",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        },
        {
            "name": "prosody",
            "type": "deployment",
            "image": "jitsi/prosody:stable-10741",
            "ports": [
                {
                    "port": 5222,
                    "protocol": "TCP",
                    "ingress": false
                },
                {
                    "port": 5280,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        },
        {
            "name": "jicofo",
            "type": "deployment",
            "image": "jitsi/jicofo:stable-10741",
            "ports": []
        },
        {
            "name": "jvb",
            "type": "deployment",
            "image": "jitsi/jvb:stable-10741",
            "ports": [
                {
                    "port": 10000,
                    "protocol": "UDP",
                    "ingress": false
                }
            ]
        },
        {
            "name": "coturn",
            "type": "deployment",
            "image": "coturn/coturn:4.9",
            "ports": [
                {
                    "port": 3478,
                    "protocol": "UDP",
                    "ingress": false
                },
                {
                    "port": 3478,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "optional": true
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and OWASP API"
            }
        ],
        "host_ports": [
            {
                "port": 10000,
                "protocol": "UDP",
                "component": "jvb",
                "description": "WebRTC media (RTP/RTCP video/audio streams)",
                "optional": false,
                "remappable": false,
                "max_instances_per_node": 1
            },
            {
                "port": 3478,
                "protocol": "UDP",
                "component": "coturn",
                "description": "STUN/TURN for NAT traversal",
                "optional": true,
                "remappable": false,
                "max_instances_per_node": 1
            }
        ],
        "websocket": true,
        "notes": "JVB requires UDP 10000 for media. Clients behind corporate firewalls may need the optional TURN server on UDP 3478. Only 1 Jitsi instance per node due to hostPort."
    },
    "volumes": [
        {
            "local_path": "applications/jitsi/config",
            "container_path": "/config",
            "size_megabytes": 100,
            "description": "Prosody XMPP configuration and certificates"
        },
        {
            "local_path": "applications/jitsi/plugins",
            "container_path": "/prosody-plugins-custom",
            "size_megabytes": 50,
            "description": "Custom Prosody plugins",
            "optional": true
        }
    ],
    "resources": {
        "default": {
            "cpu": "2.00",
            "memory": "4Gi",
            "storage": "200Mi"
        },
        "minimum": {
            "cpu": "1.00",
            "memory": "2Gi",
            "storage": "150Mi"
        }
    },
    "health_check": {
        "path": "/",
        "port": 80,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain (e.g., meet.example.com)",
            "type": "string",
            "required": true
        },
        {
            "key": "jvb.publicIP",
            "label": "Server Public IP",
            "type": "string",
            "required": true,
            "description": "Public IPv4 address for WebRTC media"
        },
        {
            "key": "jitsi.authType",
            "label": "Authentication Type",
            "type": "string",
            "default": "internal",
            "description": "internal (username/password) or jwt"
        },
        {
            "key": "jitsi.enableGuests",
            "label": "Allow Guest Access",
            "type": "boolean",
            "default": true
        },
        {
            "key": "jitsi.defaultLanguage",
            "label": "Default Language",
            "type": "string",
            "default": "en"
        },
        {
            "key": "jitsi.enableRecording",
            "label": "Enable Recording (Jibri)",
            "type": "boolean",
            "default": false
        },
        {
            "key": "jitsi.maxParticipants",
            "label": "Max Participants per Room",
            "type": "integer",
            "default": 100
        },
        {
            "key": "jitsi.enableLobby",
            "label": "Enable Lobby (waiting room)",
            "type": "boolean",
            "default": true
        },
        {
            "key": "coturn.enabled",
            "label": "Enable Built-in TURN Server",
            "type": "boolean",
            "default": false
        },
        {
            "key": "coturn.authSecret",
            "label": "TURN Shared Secret",
            "type": "secret",
            "required": false,
            "description": "Required if TURN is enabled"
        },
        {
            "key": "jvb.enableWsColibri",
            "label": "Enable WebSocket Colibri (fallback for UDP blocked)",
            "type": "boolean",
            "default": true
        }
    ],
    "tags": [
        "video",
        "conferencing",
        "webrtc",
        "meeting",
        "communication"
    ],
    "supportedVersions": [
        {
            "version": "stable-10522",
            "components": [
                {
                    "name": "web",
                    "image": "jitsi/web:stable-10522"
                },
                {
                    "name": "prosody",
                    "image": "jitsi/prosody:stable-10522"
                },
                {
                    "name": "jicofo",
                    "image": "jitsi/jicofo:stable-10522"
                },
                {
                    "name": "jvb",
                    "image": "jitsi/jvb:stable-10522"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "stable-10741",
            "components": [
                {
                    "name": "web",
                    "image": "jitsi/web:stable-10741"
                },
                {
                    "name": "prosody",
                    "image": "jitsi/prosody:stable-10741"
                },
                {
                    "name": "jicofo",
                    "image": "jitsi/jicofo:stable-10741"
                },
                {
                    "name": "jvb",
                    "image": "jitsi/jvb:stable-10741"
                }
            ],
            "upgradeFrom": [
                "stable-10522"
            ],
            "isDefault": true
        }
    ]
}
