{
    "name": "Gitea",
    "code": "gitea",
    "type": "application",
    "version": "1.25",
    "description": "A lightweight, self-hosted Git service for managing your code repositories and team collaboration.",
    "url": "https://about.gitea.com",
    "documentation": "https://docs.gitea.com",
    "category": "devtools",
    "tenancy": [
        "multi-tenant"
    ],
    "components": [
        {
            "name": "gitea",
            "type": "deployment",
            "image": "gitea/gitea:1.25",
            "ports": [
                {
                    "port": 3000,
                    "protocol": "TCP",
                    "ingress": true
                },
                {
                    "port": 22,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        },
        {
            "name": "postgresql",
            "type": "statefulset",
            "image": "postgres:17-alpine",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and Git HTTP"
            }
        ],
        "host_ports": [
            {
                "port": 2222,
                "protocol": "TCP",
                "component": "gitea",
                "description": "Git SSH access",
                "optional": true,
                "remappable": true,
                "max_instances_per_node": 1
            }
        ],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "applications/gitea/data",
            "container_path": "/data",
            "description": "Gitea repositories and data"
        },
        {
            "local_path": "applications/gitea/database",
            "container_path": "/var/lib/postgresql/data",
            "description": "PostgreSQL data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "15Gi"
        }
    },
    "health_check": {
        "path": "/api/healthz",
        "port": 3000,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "gitea.adminUser",
            "label": "Admin Username",
            "type": "string",
            "default": "gitea_admin",
            "required": true
        },
        {
            "key": "gitea.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "gitea.adminEmail",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "gitea.sshEnabled",
            "label": "Enable SSH Access",
            "type": "boolean",
            "default": true
        },
        {
            "key": "gitea.lfsEnabled",
            "label": "Enable Git LFS",
            "type": "boolean",
            "default": true
        },
        {
            "key": "postgresql.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "giteaData.storageSize",
            "label": "Repository Storage Size",
            "type": "string",
            "default": "10Gi"
        }
    ],
    "tags": [
        "git",
        "devtools",
        "gitea",
        "code"
    ],
    "supportedVersions": [
        {
            "version": "1.24",
            "components": [
                {
                    "name": "gitea",
                    "image": "gitea/gitea:1.24"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "1.25",
            "components": [
                {
                    "name": "gitea",
                    "image": "gitea/gitea:1.25"
                }
            ],
            "upgradeFrom": [
                "1.24"
            ],
            "isDefault": true
        }
    ]
}
