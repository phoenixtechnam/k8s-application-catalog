{
    "name": "n8n",
    "code": "n8n",
    "type": "application",
    "version": "2.13.4",
    "description": "Automate repetitive tasks by connecting your apps and services with visual drag-and-drop workflows.",
    "url": "https://n8n.io",
    "documentation": "https://docs.n8n.io",
    "category": "automation",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "n8n",
            "type": "deployment",
            "image": "n8nio/n8n:2.13.4",
            "ports": [
                {
                    "port": 5678,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "data"
            ]
        },
        {
            "name": "postgresql",
            "type": "deployment",
            "image": "postgres:18-alpine",
            "database": "postgresql",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "env_vars": {
                "fixed": {
                    "PGDATA": "/var/lib/postgresql/18/docker"
                }
            },
            "volumes": [
                "database"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and webhook endpoints"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "applications/n8n/data",
            "container_path": "/home/node/.n8n",
            "description": "n8n workflow data and credentials"
        },
        {
            "local_path": "applications/n8n/database",
            "container_path": "/var/lib/postgresql",
            "description": "PostgreSQL data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "10Gi"
        }
    },
    "health_check": {
        "path": "/healthz",
        "port": 5678,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "n8n.webhookUrl",
            "label": "Webhook URL",
            "type": "string",
            "required": true
        },
        {
            "key": "n8n.basicAuthUser",
            "label": "Basic Auth Username",
            "type": "string",
            "required": true
        },
        {
            "key": "n8n.basicAuthPassword",
            "label": "Basic Auth Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "n8n.encryptionKey",
            "label": "Encryption Key",
            "type": "secret",
            "required": true
        },
        {
            "key": "postgresql.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "n8nData.storageSize",
            "label": "Application Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "automation",
        "workflow",
        "n8n",
        "integration"
    ],
    "supportedVersions": [
        {
            "version": "1.88.0",
            "components": [
                {
                    "name": "n8n",
                    "image": "n8nio/n8n:1.88.0"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "2.13.4",
            "components": [
                {
                    "name": "n8n",
                    "image": "n8nio/n8n:2.13.4"
                }
            ],
            "upgradeFrom": [
                "1.88.0"
            ],
            "breakingChanges": "Major version upgrade from 1.x to 2.x. Workflow format changes may require review.",
            "isDefault": true
        }
    ]
}
