{
    "name": "MySQL 9.0",
    "code": "mysql-90",
    "type": "database",
    "version": "9.0",
    "description": "MySQL 9.0 Innovation release — for clients who specifically need MySQL over MariaDB",
    "category": "database",
    "min_plan": "starter",
    "runtime": "mysql",
    "web_server": null,
    "image": "mysql:9.0",
    "has_dockerfile": false,
    "deployment_strategy": "statefulset",
    "components": [
        {
            "name": "mysql-90",
            "type": "statefulset",
            "image": "mysql:9.0",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "name": "data",
            "mount_path": "/var/lib/mysql",
            "default_size": "5Gi",
            "description": "Database data"
        }
    ],
    "resources": {
        "default": {
            "cpu": "0.25",
            "memory": "512Mi",
            "storage": "5Gi"
        },
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi",
            "storage": "1Gi"
        }
    },
    "health_check": {
        "path": null,
        "command": [
            "mysqladmin",
            "ping",
            "-h",
            "localhost"
        ],
        "port": null,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "auth.database",
            "label": "Database Name",
            "type": "string",
            "required": true
        },
        {
            "key": "auth.username",
            "label": "Username",
            "type": "string",
            "required": true
        }
    ],
    "tags": [
        "database",
        "mysql",
        "sql"
    ],
    "provides": {
        "database": {
            "engine": "mysql",
            "version": "9.0",
            "protocol": "mysql",
            "port": 3306,
            "credentials": {
                "root_env": "MYSQL_ROOT_PASSWORD",
                "user_env": "MYSQL_USER",
                "password_env": "MYSQL_PASSWORD",
                "database_env": "MYSQL_DATABASE"
            }
        }
    },
    "env_vars": {
        "configurable": [
            "MYSQL_DATABASE",
            "MYSQL_USER"
        ],
        "generated": [
            "MYSQL_ROOT_PASSWORD",
            "MYSQL_PASSWORD"
        ],
        "fixed": {}
    }
}
