{
    "name": "Dolibarr ERP/CRM",
    "code": "dolibarr",
    "type": "application",
    "version": "20",
    "description": "Manage your business with an open-source ERP and CRM \u2014 invoicing, accounting, inventory, HR, and project management in one platform.",
    "url": "https://www.dolibarr.org",
    "documentation": "https://wiki.dolibarr.org",
    "category": "billing",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "dolibarr",
            "type": "deployment",
            "image": "tuxgasy/dolibarr:20.0.2",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "documents",
                "custom"
            ]
        },
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11.8",
            "database": "mariadb",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and REST API"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "documents",
            "container_path": "/var/www/html/documents",
            "description": "Uploaded files, generated PDFs, and attachments"
        },
        {
            "local_path": "custom",
            "container_path": "/var/www/html/custom",
            "description": "Custom modules and themes"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/mysql",
            "description": "MariaDB data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "20Gi"
        }
    },
    "health_check": {
        "path": "/index.php",
        "port": 80,
        "initial_delay_seconds": 90,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "dolibarr.adminLogin",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "dolibarr.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "dolibarr.modules",
            "label": "Enabled Modules",
            "type": "string",
            "default": ""
        },
        {
            "key": "dolibarr.phpMemoryLimit",
            "label": "PHP Memory Limit",
            "type": "string",
            "default": "256M"
        },
        {
            "key": "dolibarr.uploadMaxSize",
            "label": "Upload Max Size",
            "type": "string",
            "default": "64M"
        },
        {
            "key": "dolibarr.timezone",
            "label": "PHP Timezone",
            "type": "string",
            "default": "UTC"
        },
        {
            "key": "mariadb.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "dolibarr.storageSize",
            "label": "Documents Storage Size",
            "type": "string",
            "default": "15Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "erp",
        "crm",
        "invoicing",
        "accounting",
        "dolibarr",
        "php"
    ],
    "supportedVersions": [
        {
            "version": "19",
            "components": [
                {
                    "name": "dolibarr",
                    "image": "tuxgasy/dolibarr:19.0.3"
                }
            ],
            "eolDate": "2026-12-31",
            "migrationNotes": "Dolibarr 19.x reaches end-of-life December 2026. Upgrade to 20.x.",
            "isDefault": false
        },
        {
            "version": "20",
            "components": [
                {
                    "name": "dolibarr",
                    "image": "tuxgasy/dolibarr:20.0.2"
                }
            ],
            "upgradeFrom": [
                "19"
            ],
            "breakingChanges": "Major version upgrade. Review custom module compatibility.",
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "MARIADB_ROOT_PASSWORD",
            "DOLI_DB_PASSWORD"
        ],
        "fixed": {
            "MARIADB_DATABASE": "dolibarr",
            "MARIADB_USER": "dolibarr",
            "MARIADB_PASSWORD": "{{ENV:DOLI_DB_PASSWORD}}",
            "DOLI_DB_HOST": "{{SERVICE:mariadb}}",
            "DOLI_DB_USER": "dolibarr",
            "DOLI_DB_NAME": "dolibarr"
        },
        "configurable": [
            "DOLI_ADMIN_LOGIN",
            "DOLI_MODULE_ENABLE"
        ]
    }
}
