{
    "name": "Vaultwarden",
    "code": "vaultwarden",
    "type": "application",
    "version": "1.35.4",
    "description": "Store and sync all your passwords securely across devices with this Bitwarden-compatible vault.",
    "url": "https://github.com/dani-garcia/vaultwarden",
    "documentation": "https://github.com/dani-garcia/vaultwarden/wiki",
    "category": "security",
    "tenancy": [
        "multi-tenant"
    ],
    "components": [
        {
            "name": "vaultwarden",
            "type": "deployment",
            "image": "vaultwarden/server:1.35.4",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web vault and API"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": ".",
            "container_path": "/data",
            "description": "Vaultwarden data and SQLite database"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.10",
            "memory": "64Mi",
            "storage": "1Gi"
        },
        "recommended": {
            "cpu": "0.25",
            "memory": "128Mi",
            "storage": "1Gi"
        }
    },
    "health_check": {
        "path": "/alive",
        "port": 80,
        "initial_delay_seconds": 10,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "vaultwarden.signupsAllowed",
            "label": "Allow Signups",
            "type": "boolean",
            "default": false
        },
        {
            "key": "vaultwarden.adminToken",
            "label": "Admin Token",
            "type": "secret",
            "required": true
        },
        {
            "key": "vwData.storageSize",
            "label": "Data Storage Size",
            "type": "string",
            "default": "1Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "passwords",
        "bitwarden",
        "security",
        "vaultwarden"
    ],
    "supportedVersions": [
        {
            "version": "1.34.1",
            "components": [
                {
                    "name": "vaultwarden",
                    "image": "vaultwarden/server:1.34.1"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "1.35.4",
            "components": [
                {
                    "name": "vaultwarden",
                    "image": "vaultwarden/server:1.35.4"
                }
            ],
            "upgradeFrom": [
                "1.34.1"
            ],
            "isDefault": true
        }
    ]
}
