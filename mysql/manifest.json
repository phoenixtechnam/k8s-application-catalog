{
    "name": "MySQL",
    "code": "mysql",
    "type": "database",
    "version": "8.4",
    "description": "MySQL — dedicated instance for applications requiring MySQL specifically",
    "category": "database",
    "min_plan": "starter",
    "runtime": "mysql",
    "web_server": null,
    "image": "mysql:8.4",
    "has_dockerfile": false,
    "deployment_strategy": "deployment",
    "components": [
        {
            "name": "mysql",
            "type": "deployment",
            "image": "mysql:8.4",
            "database": "mysql",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "container_path": "/var/lib/mysql",
            "description": "Database data",
            "local_path": "."
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "512Mi",
            "storage": "1Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "1Gi",
            "storage": "5Gi"
        }
    },
    "health_check": {
        "path": null,
        "command": [
            "mysqladmin",
            "ping",
            "-h",
            "localhost"
        ],
        "port": null,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "MYSQL_DATABASE",
            "label": "Default Database",
            "type": "string",
            "default": "",
            "description": "Create a database on first startup (optional)."
        },
        {
            "key": "MYSQL_USER",
            "label": "Database User",
            "type": "string",
            "default": "",
            "description": "Create a non-root user on first startup (optional, requires MYSQL_DATABASE)."
        },
        {
            "key": "MYSQL_PASSWORD",
            "label": "Database Password",
            "type": "secret",
            "default": "",
            "description": "Password for the non-root user (optional, requires MYSQL_USER)."
        }
    ],
    "tags": [
        "database",
        "mysql",
        "sql"
    ],
    "provides": {
        "database": {
            "engine": "mysql",
            "version": "8.4",
            "protocol": "mysql",
            "port": 3306,
            "credentials": {
                "root_env": "MYSQL_ROOT_PASSWORD"
            }
        }
    },
    "env_vars": {
        "configurable": [
            "MYSQL_DATABASE",
            "MYSQL_USER",
            "MYSQL_PASSWORD"
        ],
        "generated": [
            "MYSQL_ROOT_PASSWORD"
        ],
        "fixed": {}
    },
    "supportedVersions": [
        {
            "version": "8",
            "isDefault": false,
            "upgradeFrom": [],
            "components": [
                {
                    "name": "mysql",
                    "image": "mysql:8.0"
                }
            ],
            "provides": {
                "database": {
                    "engine": "mysql",
                    "version": "8.0",
                    "protocol": "mysql",
                    "port": 3306
                }
            }
        },
        {
            "version": "8.4",
            "isDefault": true,
            "upgradeFrom": [
                "8"
            ],
            "components": [
                {
                    "name": "mysql",
                    "image": "mysql:8.4"
                }
            ],
            "provides": {
                "database": {
                    "engine": "mysql",
                    "version": "8.4",
                    "protocol": "mysql",
                    "port": 3306
                }
            }
        },
        {
            "version": "9",
            "isDefault": false,
            "upgradeFrom": [
                "8.4"
            ],
            "breakingChanges": "The mysql_native_password authentication plugin has been removed in MySQL 9. All user accounts must use caching_sha2_password. Verify application compatibility before upgrading.",
            "components": [
                {
                    "name": "mysql",
                    "image": "mysql:9"
                }
            ],
            "provides": {
                "database": {
                    "engine": "mysql",
                    "version": "9",
                    "protocol": "mysql",
                    "port": 3306
                }
            }
        }
    ]
}
