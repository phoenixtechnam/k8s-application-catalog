{
    "name": "Matomo",
    "code": "matomo",
    "type": "application",
    "version": "5",
    "description": "Track your website visitors with full privacy — a Google Analytics alternative you own and control.",
    "url": "https://matomo.org",
    "documentation": "https://matomo.org/guides/",
    "category": "analytics",
    "tenancy": [
        "multi-tenant"
    ],
    "components": [
        {
            "name": "matomo",
            "type": "deployment",
            "image": "matomo:5",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        },
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11.8",
            "database": "mariadb",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and tracking API"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "applications/matomo/data",
            "container_path": "/var/www/html",
            "description": "Matomo application data"
        },
        {
            "local_path": "applications/matomo/database",
            "container_path": "/var/lib/mysql",
            "description": "MariaDB data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "10Gi"
        }
    },
    "health_check": {
        "path": "/matomo.php",
        "port": 80,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "matomo.adminUser",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "matomo.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "mariadb.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "matomoData.storageSize",
            "label": "Application Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "analytics",
        "matomo",
        "privacy",
        "gdpr"
    ],
    "supportedVersions": [
        {
            "version": "4",
            "components": [
                {
                    "name": "matomo",
                    "image": "matomo:4"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "5",
            "components": [
                {
                    "name": "matomo",
                    "image": "matomo:5"
                }
            ],
            "upgradeFrom": [
                "4"
            ],
            "breakingChanges": "Major version upgrade. Some plugins may need updates.",
            "isDefault": true
        }
    ]
}
