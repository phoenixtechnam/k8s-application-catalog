{
    "name": "Paperless-ngx",
    "code": "paperless-ngx",
    "type": "application",
    "version": "2.20.13",
    "description": "Go paperless — scan, tag, and search all your documents from one organized digital archive.",
    "url": "https://docs.paperless-ngx.com",
    "documentation": "https://docs.paperless-ngx.com/setup/",
    "category": "productivity",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "paperless",
            "type": "deployment",
            "image": "ghcr.io/paperless-ngx/paperless-ngx:2.20.13",
            "ports": [
                {
                    "port": 8000,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        },
        {
            "name": "postgresql",
            "type": "statefulset",
            "image": "postgres:17-alpine",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP"
                }
            ]
        },
        {
            "name": "redis",
            "type": "deployment",
            "image": "redis:8-alpine",
            "ports": [
                {
                    "port": 6379,
                    "protocol": "TCP"
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 8000,
                "protocol": "TCP",
                "tls": true,
                "description": "Paperless-ngx web interface"
            }
        ]
    },
    "volumes": [
        {
            "local_path": "applications/paperless-ngx/data",
            "container_path": "/usr/src/paperless/data",
            "size_megabytes": 5120,
            "description": "Paperless application data and index"
        },
        {
            "local_path": "applications/paperless-ngx/media",
            "container_path": "/usr/src/paperless/media",
            "size_megabytes": 20480,
            "description": "Stored and processed documents"
        },
        {
            "local_path": "applications/paperless-ngx/consume",
            "container_path": "/usr/src/paperless/consume",
            "size_megabytes": 5120,
            "description": "Consumption directory for incoming documents"
        },
        {
            "local_path": "applications/paperless-ngx/database",
            "container_path": "/var/lib/postgresql/data",
            "size_megabytes": 5120,
            "description": "PostgreSQL database storage"
        }
    ],
    "resources": {
        "default": {
            "cpu": "1.00",
            "memory": "1Gi",
            "storage": "35Gi"
        },
        "minimum": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "15Gi"
        }
    },
    "health_check": {
        "path": "/",
        "port": 8000,
        "initial_delay_seconds": 60,
        "period_seconds": 10
    },
    "parameters": [
        {
            "key": "domain",
            "label": "Domain",
            "type": "string",
            "required": true,
            "description": "Fully qualified domain name for Paperless-ngx"
        },
        {
            "key": "admin.username",
            "label": "Admin Username",
            "type": "string",
            "required": true,
            "description": "Initial superuser username"
        },
        {
            "key": "admin.password",
            "label": "Admin Password",
            "type": "secret",
            "required": true,
            "description": "Initial superuser password"
        },
        {
            "key": "admin.email",
            "label": "Admin Email",
            "type": "string",
            "required": true,
            "description": "Initial superuser email address"
        },
        {
            "key": "app.secretKey",
            "label": "Secret Key",
            "type": "secret",
            "required": true,
            "description": "Django secret key for cryptographic signing"
        },
        {
            "key": "ocr.language",
            "label": "OCR Language",
            "type": "string",
            "default": "eng",
            "description": "Tesseract OCR language (e.g., eng, deu, fra)"
        },
        {
            "key": "db.password",
            "label": "Database Password",
            "type": "secret",
            "required": true,
            "description": "PostgreSQL database password"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Host",
            "type": "string",
            "description": "SMTP server hostname for email notifications"
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "description": "SMTP server port"
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "description": "SMTP authentication username"
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "description": "SMTP authentication password"
        }
    ],
    "tags": [
        "documents",
        "ocr",
        "paperless",
        "productivity"
    ],
    "supportedVersions": [
        {
            "version": "2.19.0",
            "components": [
                {
                    "name": "paperless",
                    "image": "ghcr.io/paperless-ngx/paperless-ngx:2.19.0"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Paperless-ngx 2.19.0 reaches end-of-life September 2026. Upgrade to 2.20.13.",
            "isDefault": false
        },
        {
            "version": "2.20.13",
            "components": [
                {
                    "name": "paperless",
                    "image": "ghcr.io/paperless-ngx/paperless-ngx:2.20.13"
                }
            ],
            "upgradeFrom": [
                "2.19.0"
            ],
            "isDefault": true
        }
    ]
}
