{
    "name": "Directus",
    "code": "directus",
    "type": "application",
    "version": "11",
    "description": "Turn any SQL database into a modern admin dashboard and API \u2014 no coding required.",
    "url": "https://directus.io",
    "documentation": "https://docs.directus.io",
    "category": "cms",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "directus",
            "type": "deployment",
            "image": "directus/directus:11",
            "ports": [
                {
                    "port": 8055,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "uploads",
                "extensions"
            ]
        },
        {
            "name": "postgresql",
            "type": "deployment",
            "image": "postgres:18-alpine",
            "database": "postgresql",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP"
                }
            ],
            "env_vars": {
                "fixed": {
                    "PGDATA": "/var/lib/postgresql/18/docker"
                }
            },
            "volumes": [
                "database"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 8055,
                "protocol": "TCP",
                "tls": true,
                "description": "Directus HTTP API and admin dashboard"
            }
        ],
        "websocket": true
    },
    "volumes": [
        {
            "local_path": "uploads",
            "container_path": "/directus/uploads",
            "description": "Directus file uploads"
        },
        {
            "local_path": "extensions",
            "container_path": "/directus/extensions",
            "description": "Directus custom extensions"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/postgresql",
            "description": "PostgreSQL database storage"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "6Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "16Gi"
        }
    },
    "health_check": {
        "path": "/server/health",
        "port": 8055,
        "initial_delay_seconds": 30,
        "period_seconds": 10
    },
    "parameters": [
        {
            "key": "domain",
            "label": "Domain",
            "type": "string",
            "required": true,
            "description": "Fully qualified domain name for Directus"
        },
        {
            "key": "admin.email",
            "label": "Admin Email",
            "type": "string",
            "required": true,
            "description": "Initial admin user email address"
        },
        {
            "key": "admin.password",
            "label": "Admin Password",
            "type": "secret",
            "required": true,
            "description": "Initial admin user password"
        },
        {
            "key": "app.secret",
            "label": "Application Secret",
            "type": "secret",
            "required": true,
            "description": "Secret used for signing tokens and encrypting data"
        },
        {
            "key": "db.password",
            "label": "Database Password",
            "type": "secret",
            "required": true,
            "description": "PostgreSQL database password"
        }
    ],
    "tags": [
        "cms",
        "headless",
        "directus",
        "api",
        "dashboard"
    ],
    "supportedVersions": [
        {
            "version": "10",
            "components": [
                {
                    "name": "directus",
                    "image": "directus/directus:10"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Directus 10.x reaches end-of-life September 2026. Upgrade to 11.x.",
            "isDefault": false
        },
        {
            "version": "11",
            "components": [
                {
                    "name": "directus",
                    "image": "directus/directus:11"
                }
            ],
            "upgradeFrom": [
                "10"
            ],
            "breakingChanges": "Major version upgrade. API breaking changes.",
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "POSTGRES_PASSWORD",
            "DIRECTUS_KEY",
            "DIRECTUS_SECRET"
        ],
        "fixed": {
            "POSTGRES_DB": "directus",
            "POSTGRES_USER": "directus",
            "DB_CLIENT": "pg",
            "DB_HOST": "{{SERVICE:postgresql}}",
            "DB_PORT": "5432",
            "DB_DATABASE": "directus",
            "DB_USER": "directus",
            "DB_PASSWORD": "{{ENV:POSTGRES_PASSWORD}}",
            "KEY": "{{ENV:DIRECTUS_KEY}}",
            "SECRET": "{{ENV:DIRECTUS_SECRET}}"
        },
        "configurable": [
            "ADMIN_EMAIL",
            "ADMIN_PASSWORD"
        ]
    }
}
