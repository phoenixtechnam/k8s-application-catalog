{
    "name": "WordPress",
    "code": "wordpress",
    "type": "application",
    "version": "6.9",
    "description": "Create and manage your own website or blog with the world's most popular content management system.",
    "url": "https://wordpress.org",
    "documentation": "https://learn.wordpress.org/course/beginner-wordpress-user/",
    "category": "cms",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "wordpress",
            "type": "deployment",
            "image": "wordpress:6.9-php8.4-apache",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "content"
            ]
        },
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11.8",
            "database": "mariadb",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        },
        {
            "name": "redis",
            "type": "deployment",
            "image": "redis:8-alpine",
            "ports": [
                {
                    "port": 6379,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "optional": true,
            "volumes": []
        },
        {
            "name": "wp-cron",
            "type": "cronjob",
            "image": "wordpress:6.9-php8.4-apache",
            "schedule": "*/15 * * * *",
            "optional": true,
            "volumes": [
                "content"
            ]
        },
        {
            "name": "wp-install",
            "type": "job",
            "image": "wordpress:cli-2.12.0-php8.4",
            "volumes": [],
            "resources": { "cpu": "100m", "memory": "512Mi" },
            "command": [
                "sh",
                "-c",
                "set -e; export WP_CLI_PHP_ARGS='-d memory_limit=384M'; WP_PATH=/tmp/wp; mkdir -p $WP_PATH && cd $WP_PATH; [ -f wp-load.php ] || wp core download --allow-root --path=$WP_PATH --force; wp config create --allow-root --path=$WP_PATH --force --dbname=\"$WORDPRESS_DB_NAME\" --dbuser=\"$WORDPRESS_DB_USER\" --dbpass=\"$WORDPRESS_DB_PASSWORD\" --dbhost=\"$WORDPRESS_DB_HOST\"; i=0; until wp db check --allow-root --path=$WP_PATH 2>/dev/null; do i=$((i+1)); [ $i -gt 60 ] && echo db-timeout && exit 1; echo waiting-for-db attempt $i; sleep 3; done; if wp core is-installed --allow-root --path=$WP_PATH 2>/dev/null; then echo already-installed; exit 0; fi; wp core install --allow-root --path=$WP_PATH --url=\"https://$WORDPRESS_URL\" --title=\"$WORDPRESS_SITE_TITLE\" --admin_user=\"$WORDPRESS_ADMIN_USER\" --admin_password=\"$WORDPRESS_ADMIN_PASSWORD\" --admin_email=\"$WORDPRESS_ADMIN_EMAIL\" --skip-email; echo installed"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and REST API"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "applications/wordpress/content",
            "container_path": "/var/www/html/wp-content",
            "description": "Themes, plugins, uploads, and media files"
        },
        {
            "local_path": "applications/wordpress/database",
            "container_path": "/var/lib/mysql",
            "description": "MariaDB data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "15Gi"
        }
    },
    "health_check": {
        "path": "/wp-login.php",
        "port": 80,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "env_vars": {
        "generated": [
            "MARIADB_ROOT_PASSWORD",
            "WORDPRESS_DB_PASSWORD"
        ],
        "fixed": {
            "MARIADB_DATABASE": "wordpress",
            "MARIADB_USER": "wordpress",
            "MARIADB_PASSWORD": "{{ENV:WORDPRESS_DB_PASSWORD}}",
            "WORDPRESS_DB_HOST": "{{SERVICE:mariadb}}",
            "WORDPRESS_DB_NAME": "wordpress",
            "WORDPRESS_DB_USER": "wordpress"
        },
        "configurable": [
            "WORDPRESS_URL",
            "WORDPRESS_SITE_TITLE",
            "WORDPRESS_ADMIN_USER",
            "WORDPRESS_ADMIN_PASSWORD",
            "WORDPRESS_ADMIN_EMAIL",
            "WORDPRESS_TABLE_PREFIX",
            "WORDPRESS_DEBUG",
            "WORDPRESS_CONFIG_EXTRA"
        ]
    },
    "parameters": [
        {
            "key": "WORDPRESS_URL",
            "label": "Domain",
            "type": "string",
            "required": true,
            "description": "Hostname at which WordPress will be reachable (e.g. blog.example.com). Used by the installer to set the site URL."
        },
        {
            "key": "WORDPRESS_SITE_TITLE",
            "label": "Site Title",
            "type": "string",
            "default": "My WordPress Site",
            "required": true,
            "description": "Applied automatically by the one-shot wp-install job on first deploy."
        },
        {
            "key": "WORDPRESS_ADMIN_USER",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "WORDPRESS_ADMIN_PASSWORD",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "WORDPRESS_ADMIN_EMAIL",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "WORDPRESS_TABLE_PREFIX",
            "label": "Database Table Prefix",
            "type": "string",
            "default": "wp_",
            "advanced": true,
            "description": "Prefix for WordPress tables. Rarely needs to change."
        },
        {
            "key": "WORDPRESS_DEBUG",
            "label": "WordPress Debug Mode",
            "type": "boolean",
            "default": false,
            "advanced": true,
            "description": "Enables WP_DEBUG in wp-config.php. Verbose — leave off in production."
        },
        {
            "key": "WORDPRESS_CONFIG_EXTRA",
            "label": "Extra wp-config.php",
            "type": "string",
            "advanced": true,
            "description": "Raw PHP appended to wp-config.php (e.g. define() lines)."
        },
        {
            "key": "wordpress.phpMemoryLimit",
            "label": "PHP Memory Limit",
            "type": "string",
            "default": "256M",
            "advanced": true
        },
        {
            "key": "wordpress.uploadMaxSize",
            "label": "Upload Max Size",
            "type": "string",
            "default": "64M",
            "advanced": true
        },
        {
            "key": "wordpress.maxExecutionTime",
            "label": "Max Execution Time (seconds)",
            "type": "integer",
            "default": 300,
            "advanced": true
        },
        {
            "key": "redis.enabled",
            "label": "Enable Redis Object Cache",
            "type": "boolean",
            "default": true,
            "advanced": true
        },
        {
            "key": "cron.enabled",
            "label": "Enable WP-Cron via Kubernetes",
            "type": "boolean",
            "default": true,
            "advanced": true
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "advanced": true
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "advanced": true
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "advanced": true
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "advanced": true
        }
    ],
    "tags": [
        "cms",
        "wordpress",
        "php",
        "blog",
        "website"
    ],
    "supportedVersions": [
        {
            "version": "6.7",
            "components": [
                {
                    "name": "wordpress",
                    "image": "wordpress:6.7-php8.3-apache"
                },
                {
                    "name": "wp-cron",
                    "image": "wordpress:6.7-php8.3-apache"
                }
            ],
            "eolDate": "2026-04-30",
            "migrationNotes": "WordPress 6.7 reaches end-of-life April 2026. Upgrade to 6.8 or 6.9.",
            "isDefault": false
        },
        {
            "version": "6.8",
            "components": [
                {
                    "name": "wordpress",
                    "image": "wordpress:6.8-php8.4-apache"
                },
                {
                    "name": "wp-cron",
                    "image": "wordpress:6.8-php8.4-apache"
                }
            ],
            "upgradeFrom": [
                "6.7"
            ],
            "eolDate": "2026-09-30",
            "breakingChanges": "PHP minimum bumped from 8.1 to 8.2. Some classic editor plugins may need updates.",
            "isDefault": false
        },
        {
            "version": "6.9",
            "components": [
                {
                    "name": "wordpress",
                    "image": "wordpress:6.9-php8.4-apache"
                },
                {
                    "name": "wp-cron",
                    "image": "wordpress:6.9-php8.4-apache"
                }
            ],
            "upgradeFrom": [
                "6.7",
                "6.8"
            ],
            "migrationNotes": "Direct upgrade from 6.7 or 6.8 supported. No database migration needed.",
            "isDefault": true
        }
    ]
}
