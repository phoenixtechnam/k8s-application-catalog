{
    "name": "WordPress",
    "code": "wordpress",
    "type": "application",
    "version": "6.9",
    "description": "Create and manage your own website or blog with the world's most popular content management system.",
    "url": "https://wordpress.org",
    "documentation": "https://learn.wordpress.org/course/beginner-wordpress-user/",
    "category": "cms",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "wordpress",
            "type": "deployment",
            "image": "wordpress:6.9-php8.4-apache",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        },
        {
            "name": "mariadb",
            "type": "statefulset",
            "image": "mariadb:11.8",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        },
        {
            "name": "redis",
            "type": "deployment",
            "image": "redis:8-alpine",
            "ports": [
                {
                    "port": 6379,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "optional": true
        },
        {
            "name": "wp-cron",
            "type": "cronjob",
            "image": "wordpress:6.9-php8.4-apache",
            "schedule": "*/15 * * * *",
            "optional": true
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI and REST API"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "name": "wordpress-content",
            "mount_path": "/var/www/html/wp-content",
            "default_size": "10Gi",
            "description": "Themes, plugins, uploads, and media files"
        },
        {
            "name": "wordpress-database",
            "mount_path": "/var/lib/mysql",
            "default_size": "5Gi",
            "description": "MariaDB data directory"
        }
    ],
    "resources": {
        "default": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "15Gi"
        },
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        }
    },
    "health_check": {
        "path": "/wp-login.php",
        "port": 80,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "wordpress.siteTitle",
            "label": "Site Title",
            "type": "string",
            "default": "My WordPress Site",
            "required": true
        },
        {
            "key": "wordpress.adminUser",
            "label": "Admin Username",
            "type": "string",
            "default": "admin",
            "required": true
        },
        {
            "key": "wordpress.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "wordpress.adminEmail",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "wordpress.phpMemoryLimit",
            "label": "PHP Memory Limit",
            "type": "string",
            "default": "256M"
        },
        {
            "key": "wordpress.uploadMaxSize",
            "label": "Upload Max Size",
            "type": "string",
            "default": "64M"
        },
        {
            "key": "wordpress.maxExecutionTime",
            "label": "Max Execution Time (seconds)",
            "type": "integer",
            "default": 300
        },
        {
            "key": "redis.enabled",
            "label": "Enable Redis Object Cache",
            "type": "boolean",
            "default": true
        },
        {
            "key": "cron.enabled",
            "label": "Enable WP-Cron via Kubernetes",
            "type": "boolean",
            "default": true
        },
        {
            "key": "mariadb.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "wpContent.storageSize",
            "label": "Content Storage Size",
            "type": "string",
            "default": "10Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "cms",
        "wordpress",
        "php",
        "blog",
        "website"
    ],
    "supportedVersions": [
        {
            "version": "6.7",
            "components": [
                {
                    "name": "wordpress",
                    "image": "wordpress:6.7-php8.3-apache"
                },
                {
                    "name": "wp-cron",
                    "image": "wordpress:6.7-php8.3-apache"
                }
            ],
            "eolDate": "2026-04-30",
            "migrationNotes": "WordPress 6.7 reaches end-of-life April 2026. Upgrade to 6.8 or 6.9.",
            "isDefault": false
        },
        {
            "version": "6.8",
            "components": [
                {
                    "name": "wordpress",
                    "image": "wordpress:6.8-php8.4-apache"
                },
                {
                    "name": "wp-cron",
                    "image": "wordpress:6.8-php8.4-apache"
                }
            ],
            "upgradeFrom": [
                "6.7"
            ],
            "eolDate": "2026-09-30",
            "breakingChanges": "PHP minimum bumped from 8.1 to 8.2. Some classic editor plugins may need updates.",
            "isDefault": false
        },
        {
            "version": "6.9",
            "components": [
                {
                    "name": "wordpress",
                    "image": "wordpress:6.9-php8.4-apache"
                },
                {
                    "name": "wp-cron",
                    "image": "wordpress:6.9-php8.4-apache"
                }
            ],
            "upgradeFrom": [
                "6.7",
                "6.8"
            ],
            "migrationNotes": "Direct upgrade from 6.7 or 6.8 supported. No database migration needed.",
            "isDefault": true
        }
    ]
}
