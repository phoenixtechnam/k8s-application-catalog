{
    "name": "PostgreSQL",
    "code": "postgresql",
    "type": "database",
    "version": "18",
    "description": "PostgreSQL — dedicated instance for client databases with multiple version support",
    "category": "database",
    "min_plan": "starter",
    "runtime": "postgresql",
    "web_server": null,
    "image": "postgres:18",
    "has_dockerfile": false,
    "deployment_strategy": "deployment",
    "components": [
        {
            "name": "postgresql",
            "type": "deployment",
            "image": "postgres:18",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "databases/postgresql",
            "container_path": "/var/lib/postgresql/data",
            "description": "Database data"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi",
            "storage": "1Gi"
        },
        "recommended": {
            "cpu": "0.25",
            "memory": "512Mi",
            "storage": "5Gi"
        }
    },
    "health_check": {
        "path": null,
        "command": [
            "pg_isready",
            "-U",
            "postgres"
        ],
        "port": null,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [],
    "tags": [
        "database",
        "postgresql",
        "postgres",
        "sql"
    ],
    "provides": {
        "database": {
            "engine": "postgresql",
            "version": "18",
            "protocol": "postgresql",
            "port": 5432,
            "credentials": {
                "root_env": "POSTGRES_PASSWORD"
            }
        }
    },
    "env_vars": {
        "configurable": [],
        "generated": [
            "POSTGRES_PASSWORD"
        ],
        "fixed": {}
    },
    "supportedVersions": [
        {
            "version": "17",
            "isDefault": false,
            "upgradeFrom": [],
            "minPlan": "starter",
            "components": [
                {
                    "name": "postgresql",
                    "image": "postgres:17"
                }
            ],
            "provides": {
                "database": {
                    "engine": "postgresql",
                    "version": "17",
                    "protocol": "postgresql",
                    "port": 5432
                }
            }
        },
        {
            "version": "18",
            "isDefault": true,
            "upgradeFrom": [
                "17"
            ],
            "minPlan": "starter",
            "components": [
                {
                    "name": "postgresql",
                    "image": "postgres:18"
                }
            ],
            "volumes": [
                {
                    "local_path": "databases/postgresql",
                    "container_path": "/var/lib/postgresql",
                    "description": "Database data (PG 18+ convention: mount parent dir)"
                }
            ],
            "env_vars": {
                "fixed": {
                    "PGDATA": "/var/lib/postgresql/18/docker"
                }
            },
            "migrationNotes": "PostgreSQL 18 changed the default data directory convention. The image now expects the mount at /var/lib/postgresql (not /var/lib/postgresql/data) and stores data in a versioned subdirectory. Upgrading from v17 requires manual data migration — the data must be moved from /var/lib/postgresql/data/* to /var/lib/postgresql/18/docker/* (or use pg_upgrade). In-place upgrade is NOT automatic.",
            "provides": {
                "database": {
                    "engine": "postgresql",
                    "version": "18",
                    "protocol": "postgresql",
                    "port": 5432
                }
            }
        }
    ]
}
