{
    "name": "MariaDB",
    "code": "mariadb",
    "type": "database",
    "version": "11",
    "description": "MariaDB — dedicated instance for client databases with multiple version support",
    "category": "database",
    "min_plan": "starter",
    "runtime": "mariadb",
    "web_server": null,
    "image": "mariadb:11",
    "has_dockerfile": false,
    "deployment_strategy": "deployment",
    "components": [
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11",
            "database": "mariadb",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "container_path": "/var/lib/mysql",
            "description": "Database data",
            "local_path": "."
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.10",
            "memory": "256Mi",
            "storage": "1Gi"
        },
        "recommended": {
            "cpu": "0.25",
            "memory": "768Mi",
            "storage": "5Gi"
        }
    },
    "health_check": {
        "path": null,
        "command": [
            "healthcheck.sh",
            "--connect",
            "--innodb_initialized"
        ],
        "port": null,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "MARIADB_DATABASE",
            "label": "Default Database",
            "type": "string",
            "default": "",
            "description": "Create a database on first startup (optional)."
        },
        {
            "key": "MARIADB_USER",
            "label": "Database User",
            "type": "string",
            "default": "",
            "description": "Create a non-root user on first startup (optional, requires MARIADB_DATABASE)."
        },
        {
            "key": "MARIADB_PASSWORD",
            "label": "Database Password",
            "type": "secret",
            "default": "",
            "description": "Password for the non-root user (optional, requires MARIADB_USER)."
        }
    ],
    "tags": [
        "database",
        "mariadb",
        "mysql-compatible",
        "sql",
        "lts"
    ],
    "provides": {
        "database": {
            "engine": "mariadb",
            "version": "11",
            "protocol": "mysql",
            "port": 3306,
            "credentials": {
                "root_env": "MARIADB_ROOT_PASSWORD"
            }
        }
    },
    "env_vars": {
        "configurable": [
            "MARIADB_DATABASE",
            "MARIADB_USER",
            "MARIADB_PASSWORD"
        ],
        "generated": [
            "MARIADB_ROOT_PASSWORD"
        ],
        "fixed": {
            "MARIADB_AUTO_UPGRADE": "1",
            "LD_PRELOAD": "/usr/lib/x86_64-linux-gnu/libjemalloc.so.2"
        }
    },
    "supportedVersions": [
        {
            "version": "10",
            "isDefault": false,
            "upgradeFrom": [],
            "components": [
                {
                    "name": "mariadb",
                    "image": "mariadb:10"
                }
            ],
            "provides": {
                "database": {
                    "engine": "mariadb",
                    "version": "10",
                    "protocol": "mysql",
                    "port": 3306
                }
            }
        },
        {
            "version": "11",
            "isDefault": true,
            "upgradeFrom": [
                "10"
            ],
            "components": [
                {
                    "name": "mariadb",
                    "image": "mariadb:11"
                }
            ],
            "provides": {
                "database": {
                    "engine": "mariadb",
                    "version": "11",
                    "protocol": "mysql",
                    "port": 3306
                }
            }
        },
        {
            "version": "12",
            "isDefault": false,
            "upgradeFrom": [
                "11"
            ],
            "components": [
                {
                    "name": "mariadb",
                    "image": "mariadb:12"
                }
            ],
            "provides": {
                "database": {
                    "engine": "mariadb",
                    "version": "12",
                    "protocol": "mysql",
                    "port": 3306
                }
            }
        }
    ]
}
