{
    "name": "Strapi CMS",
    "code": "strapi",
    "type": "application",
    "version": "5",
    "description": "Build and manage your content with a flexible headless CMS that powers websites, apps, and more.",
    "url": "https://strapi.io",
    "documentation": "https://docs.strapi.io",
    "category": "cms",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "strapi",
            "type": "deployment",
            "image": "node:22-alpine",
            "ports": [
                {
                    "port": 1337,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        },
        {
            "name": "postgresql",
            "type": "statefulset",
            "image": "postgres:17-alpine",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP"
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 1337,
                "protocol": "TCP",
                "tls": true,
                "description": "Strapi HTTP API and admin panel"
            }
        ]
    },
    "volumes": [
        {
            "local_path": "applications/strapi/data",
            "container_path": "/opt/app",
            "description": "Strapi application data"
        },
        {
            "local_path": "applications/strapi/database",
            "container_path": "/var/lib/postgresql/data",
            "description": "PostgreSQL database storage"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "5Gi"
        },
        "recommended": {
            "cpu": "0.50",
            "memory": "512Mi",
            "storage": "10Gi"
        }
    },
    "health_check": {
        "path": "/_health",
        "port": 1337,
        "initial_delay_seconds": 30,
        "period_seconds": 10
    },
    "parameters": [
        {
            "key": "domain",
            "label": "Domain",
            "type": "string",
            "required": true,
            "description": "Fully qualified domain name for Strapi"
        },
        {
            "key": "admin.jwtSecret",
            "label": "Admin JWT Secret",
            "type": "secret",
            "required": true,
            "description": "Secret key for signing admin JWT tokens"
        },
        {
            "key": "app.keys",
            "label": "App Keys",
            "type": "secret",
            "required": true,
            "description": "Comma-separated application keys for session encryption"
        },
        {
            "key": "app.apiTokenSalt",
            "label": "API Token Salt",
            "type": "secret",
            "required": true,
            "description": "Salt used for generating API tokens"
        },
        {
            "key": "app.transferTokenSalt",
            "label": "Transfer Token Salt",
            "type": "secret",
            "required": true,
            "description": "Salt used for generating transfer tokens"
        },
        {
            "key": "db.password",
            "label": "Database Password",
            "type": "secret",
            "required": true,
            "description": "PostgreSQL database password"
        }
    ],
    "tags": [
        "cms",
        "headless",
        "strapi",
        "api"
    ],
    "supportedVersions": [
        {
            "version": "4",
            "components": [
                {
                    "name": "strapi",
                    "image": "node:22-alpine"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Strapi v4 reaches end-of-life September 2026. Upgrade to v5.",
            "isDefault": false
        },
        {
            "version": "5",
            "components": [
                {
                    "name": "strapi",
                    "image": "node:22-alpine"
                }
            ],
            "upgradeFrom": [
                "4"
            ],
            "breakingChanges": "Major version upgrade from Strapi v4 to v5. Content-type schema changes.",
            "isDefault": true
        }
    ]
}
