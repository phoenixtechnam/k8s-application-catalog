{
    "name": "Discourse",
    "code": "discourse",
    "type": "application",
    "version": "3",
    "description": "Build an online community with modern discussion forums, categories, and user engagement features.",
    "url": "https://www.discourse.org",
    "documentation": "https://meta.discourse.org/docs",
    "category": "community",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "discourse",
            "type": "deployment",
            "image": "bitnami/discourse:3",
            "ports": [
                {
                    "port": 3000,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "data"
            ]
        },
        {
            "name": "postgresql",
            "type": "deployment",
            "image": "postgres:17-alpine",
            "ports": [
                {
                    "port": 5432,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        },
        {
            "name": "redis",
            "type": "deployment",
            "image": "redis:8-alpine",
            "ports": [
                {
                    "port": 6379,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": []
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "data",
            "container_path": "/shared",
            "description": "Discourse shared data and uploads"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/postgresql/data",
            "description": "PostgreSQL data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.50",
            "memory": "1Gi",
            "storage": "15Gi"
        },
        "recommended": {
            "cpu": "1.00",
            "memory": "2Gi",
            "storage": "30Gi"
        }
    },
    "health_check": {
        "path": "/srv/status",
        "port": 3000,
        "initial_delay_seconds": 120,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "discourse.adminEmail",
            "label": "Admin Email",
            "type": "string",
            "required": true
        },
        {
            "key": "discourse.adminPassword",
            "label": "Admin Password",
            "type": "secret",
            "required": true
        },
        {
            "key": "discourse.siteName",
            "label": "Site Name",
            "type": "string",
            "default": "My Discourse Forum",
            "required": true
        },
        {
            "key": "postgresql.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "10Gi"
        },
        {
            "key": "discourseData.storageSize",
            "label": "Application Storage Size",
            "type": "string",
            "default": "20Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": true
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": true
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": true
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": true
        }
    ],
    "tags": [
        "forum",
        "community",
        "discourse",
        "discussion"
    ],
    "supportedVersions": [
        {
            "version": "2",
            "components": [
                {
                    "name": "discourse",
                    "image": "bitnami/discourse:2"
                }
            ],
            "eolDate": "2026-09-30",
            "migrationNotes": "Discourse 2.x reaches end-of-life September 2026. Upgrade to 3.x.",
            "isDefault": false
        },
        {
            "version": "3",
            "components": [
                {
                    "name": "discourse",
                    "image": "bitnami/discourse:3"
                }
            ],
            "upgradeFrom": [
                "2"
            ],
            "breakingChanges": "Major version upgrade. Check plugin compatibility.",
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "POSTGRES_PASSWORD"
        ],
        "fixed": {
            "POSTGRES_DB": "discourse",
            "POSTGRES_USER": "discourse",
            "DISCOURSE_DATABASE_HOST": "{{SERVICE:postgresql}}",
            "DISCOURSE_DATABASE_PORT_NUMBER": "5432",
            "DISCOURSE_DATABASE_NAME": "discourse",
            "DISCOURSE_DATABASE_USER": "discourse",
            "DISCOURSE_DATABASE_PASSWORD": "{{ENV:POSTGRES_PASSWORD}}",
            "DISCOURSE_REDIS_HOST": "{{SERVICE:redis}}",
            "DISCOURSE_REDIS_PORT_NUMBER": "6379"
        },
        "configurable": [
            "DISCOURSE_HOSTNAME",
            "DISCOURSE_DEVELOPER_EMAILS"
        ]
    }
}
