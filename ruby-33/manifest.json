{
    "name": "Ruby 3.3",
    "code": "ruby-33",
    "type": "runtime",
    "version": "3.3",
    "description": "Ruby 3.3 runtime with Puma web server for Rails and Rack applications",
    "category": "runtime",
    "min_plan": "starter",
    "runtime": "ruby",
    "web_server": "puma",
    "image": null,
    "has_dockerfile": true,
    "deployment_strategy": "deployment",
    "components": [
        {
            "name": "ruby-33",
            "type": "deployment",
            "image": "ghcr.io/phoenixtechnam/k8s-application-catalog/ruby-33:3.3",
            "ports": [
                {
                    "port": 3000,
                    "protocol": "TCP",
                    "ingress": true
                }
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web traffic"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "runtimes/ruby-33",
            "container_path": "/app",
            "size_megabytes": 5120,
            "description": "Application directory"
        }
    ],
    "resources": {
        "default": {
            "cpu": "0.25",
            "memory": "256Mi"
        },
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi"
        }
    },
    "health_check": {
        "path": "/health",
        "command": null,
        "port": 3000,
        "initial_delay_seconds": 30,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "env.RAILS_ENV",
            "label": "Rails Env",
            "type": "string"
        },
        {
            "key": "env.DATABASE_URL",
            "label": "Database Url",
            "type": "string"
        }
    ],
    "tags": [
        "ruby",
        "rails",
        "puma"
    ],
    "services": {
        "database": {
            "required": false,
            "engines": [
                {
                    "type": "mariadb",
                    "min_version": "10.4"
                },
                {
                    "type": "mysql",
                    "min_version": "5.7"
                },
                {
                    "type": "postgresql",
                    "min_version": "12"
                }
            ],
            "env_mapping": {
                "url": "DATABASE_URL"
            }
        }
    },
    "env_vars": {
        "configurable": [
            "RAILS_ENV",
            "DATABASE_URL"
        ],
        "fixed": {
            "PORT": "3000"
        }
    }
}
