{
    "name": "BookStack",
    "code": "bookstack",
    "type": "application",
    "version": "26.03.2",
    "description": "Organize your team's knowledge with an easy-to-use wiki that anyone can edit and search.",
    "url": "https://www.bookstackapp.com",
    "documentation": "https://www.bookstackapp.com/docs/",
    "category": "documentation",
    "tenancy": [
        "single-tenant"
    ],
    "components": [
        {
            "name": "bookstack",
            "type": "deployment",
            "image": "lscr.io/linuxserver/bookstack:v26.03.2",
            "ports": [
                {
                    "port": 80,
                    "protocol": "TCP",
                    "ingress": true
                }
            ],
            "volumes": [
                "config"
            ]
        },
        {
            "name": "mariadb",
            "type": "deployment",
            "image": "mariadb:11.8",
            "ports": [
                {
                    "port": 3306,
                    "protocol": "TCP",
                    "ingress": false
                }
            ],
            "volumes": [
                "database"
            ]
        }
    ],
    "networking": {
        "ingress_ports": [
            {
                "port": 443,
                "protocol": "TCP",
                "tls": true,
                "description": "Web UI"
            }
        ],
        "host_ports": [],
        "websocket": false
    },
    "volumes": [
        {
            "local_path": "config",
            "container_path": "/config",
            "description": "BookStack configuration and uploads"
        },
        {
            "local_path": "database",
            "container_path": "/var/lib/mysql",
            "description": "MariaDB data directory"
        }
    ],
    "resources": {
        "minimum": {
            "cpu": "0.10",
            "memory": "128Mi",
            "storage": "3Gi"
        },
        "recommended": {
            "cpu": "0.25",
            "memory": "256Mi",
            "storage": "7Gi"
        }
    },
    "health_check": {
        "path": "/login",
        "port": 80,
        "initial_delay_seconds": 60,
        "period_seconds": 30
    },
    "parameters": [
        {
            "key": "ingress.domain",
            "label": "Domain",
            "type": "string",
            "required": true
        },
        {
            "key": "bookstack.appUrl",
            "label": "Application URL",
            "type": "string",
            "required": true
        },
        {
            "key": "mariadb.storageSize",
            "label": "Database Storage Size",
            "type": "string",
            "default": "5Gi"
        },
        {
            "key": "bookstackData.storageSize",
            "label": "Application Storage Size",
            "type": "string",
            "default": "2Gi"
        },
        {
            "key": "smtp.host",
            "label": "SMTP Server",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.port",
            "label": "SMTP Port",
            "type": "integer",
            "default": 587,
            "required": false
        },
        {
            "key": "smtp.username",
            "label": "SMTP Username",
            "type": "string",
            "required": false
        },
        {
            "key": "smtp.password",
            "label": "SMTP Password",
            "type": "secret",
            "required": false
        }
    ],
    "tags": [
        "wiki",
        "documentation",
        "knowledge-base",
        "bookstack"
    ],
    "supportedVersions": [
        {
            "version": "25.12.1",
            "components": [
                {
                    "name": "bookstack",
                    "image": "lscr.io/linuxserver/bookstack:v25.12.1"
                }
            ],
            "eolDate": "2026-09-30",
            "isDefault": false
        },
        {
            "version": "26.03.2",
            "components": [
                {
                    "name": "bookstack",
                    "image": "lscr.io/linuxserver/bookstack:v26.03.2"
                }
            ],
            "upgradeFrom": [
                "25.12.1"
            ],
            "isDefault": true
        }
    ],
    "env_vars": {
        "generated": [
            "MARIADB_ROOT_PASSWORD",
            "BOOKSTACK_DB_PASSWORD"
        ],
        "fixed": {
            "MARIADB_DATABASE": "bookstack",
            "MARIADB_USER": "bookstack",
            "MARIADB_PASSWORD": "{{ENV:BOOKSTACK_DB_PASSWORD}}",
            "DB_HOST": "{{SERVICE:mariadb}}",
            "DB_PORT": "3306",
            "DB_DATABASE": "bookstack",
            "DB_USERNAME": "bookstack",
            "DB_PASSWORD": "{{ENV:BOOKSTACK_DB_PASSWORD}}"
        },
        "configurable": [
            "APP_DEBUG",
            "APP_URL"
        ]
    }
}
